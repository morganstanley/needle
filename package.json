{
    "version": "1.0.0",
    "description": "A small & lightweight dependency injection container for use in multiple contexts like Angular, React & Node.",
    "name": "@morgan-stanley/needle",
    "license": "Apache-2.0",
    "author": "Morgan Stanley",
    "type": "module",
    "main": "./dist/main/index.js",
    "module": "./dist/main/index.js",
    "types": "./dist/main/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/main/index.d.ts",
            "import": "./dist/main/index.js"
        }
    },
    "keywords": [
        "injection",
        "dependency injection",
        "IOC",
        "testability",
        "container",
        "universal",
        "isomorphic",
        "morgan stanley"
    ],
    "scripts": {
        "clean": "rimraf dist reports ../build ../install ../packages docs",
        "build": "tsc -p main/tsconfig.json",
        "postbuild": "npm run copy",
        "build:watch": "tsc --watch -p main/tsconfig.json",
        "build:verify": "concurrently --kill-others-on-fail npm:lint npm:test npm:build", 
        "build:release": "npm run clean && npm run build:verify &&npm run bench && typedoc main/index.ts",
        "copy": "copyfiles main/**/*.html main/**/*.css main/**/*.jpg dist",
        "bench": "node -e \"require('fs').mkdirSync('reports/bench',{recursive:true})\" && vitest bench --run --config vitest.bench.config.ts --outputJson reports/bench/bench-results.json",
        "bench:report": "npm run bench && node bench/generate-bench-report.mjs",
        "bench:report:html": "node bench/generate-bench-report.mjs",
        "test": "npm run test:types && vitest run",
        "test:types": "tsc -p spec/tsconfig.json --noEmit",
        "test:watch": "vitest",
        "test:watch:coverage": "vitest --coverage",
        "lint": "eslint . --ext .ts,.js",
        "lint:fix": "eslint . --ext .ts,.js --fix",
        "prepublishOnly": "npm run build:release"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^3.2.4",
        "@eslint/js": "^9.22.0",
        "@types/node": "^24.5.2",
        "@typescript-eslint/eslint-plugin": "^8.35.0",
        "@typescript-eslint/parser": "^8.35.0",
        "ajv": "^6.10.2",
        "concurrently": "^9.1.0",
        "copyfiles": "^2.4.1",
        "eslint": "^9.30.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.5.1",
        "eslint-plugin-promise": "^7.2.1",
        "globals": "^17.0.0",
        "jsdom": "^26.1.0",
        "prettier": "^3.6.2",
        "reflect-metadata": "^0.2.2",
        "rimraf": "^6.0.1",
        "source-map": "0.7.6",
        "typedoc": "^0.28.15",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.26.1",
        "unplugin-swc": "^1.5.8",
        "vite-tsconfig-paths": "^5.1.4",
        "vitest": "^3.2.4"
    },
    "peerDependencies": {
        "typescript": ">=3.4"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/morganstanley/needle"
    },
    "publishConfig": {
        "access": "public"
    }
}
